################################################################################
# Telegram Bot Configuration
################################################################################

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram Chat ID (use @getidsbot to get group ID)
# For personal chat: use numeric ID
# For group: use -100xxxxxxxxxx format
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

################################################################################
# Bot Configuration
################################################################################

# Trading Symbol (BTCUSDT, ETHUSDT, etc.)
BOT_SYMBOL=BTCUSDT

# Exchange (BINANCE, KUCOIN, BYBIT)
BOT_EXCHANGE=BINANCE

# Timeframe (1h, 4h, 1D)
BOT_TIMEFRAME=1h

# RSI Thresholds
BOT_BULLISH_THRESHOLD=60
BOT_BEARISH_THRESHOLD=50

# Check Interval (seconds)
BOT_CHECK_INTERVAL=300

################################################################################
# Advanced Configuration (Optional)
################################################################################

# Signal Mode: threshold (RSI-only) or confluence (multi-indicator)
BOT_SIGNAL_MODE=confluence

# Multi-Timeframe Analysis: true or false
BOT_USE_MULTI_TIMEFRAME=true

# Alert Cooldown (seconds, default: 3600 = 1 hour)
# BOT_ALERT_COOLDOWN=3600

# Risk Percentage for Stop Loss (default: 0.01 = 1%)
# BOT_RISK_PCT=0.01
